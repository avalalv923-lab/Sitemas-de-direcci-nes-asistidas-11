ableInPage</key><value>false</value></odeNavStructureProperty><odeNavStructureProperty><key>titlePage</key><value>ACTIVIDAD DE DESARROLLO</value></odeNavStructureProperty><odeNavStructureProperty><key>visibility</key><value>true</value></odeNavStructureProperty><odeNavStructureProperty><key>highlight</key><value>true</value></odeNavStructureProperty><odeNavStructureProperty><key>description</key><value/></odeNavStructureProperty></odeNavStructureProperties><odePagStructures><odePagStructure><odePageId>20260423164356LQTKQY</odePageId><odeBlockId>20260423164356TPWPPJ</odeBlockId><blockName>Texto</blockName><iconName>activity</iconName><odePagStructureOrder>1</odePagStructureOrder><odePagStructureProperties><odePagStructureProperty><key>visibility</key><value>true</value></odePagStructureProperty><odePagStructureProperty><key>teacherOnly</key><value>false</value></odePagStructureProperty><odePagStructureProperty><key>allowToggle</key><value>true</value></odePagStructureProperty><odePagStructureProperty><key>minimized</key><value>false</value></odePagStructureProperty><odePagStructureProperty><key>identifier</key><value/></odePagStructureProperty><odePagStructureProperty><key>cssClass</key><value/></odePagStructureProperty></odePagStructureProperties><odeComponents><odeComponent><odePageId>20260423164356LQTKQY</odePageId><odeBlockId>20260423164356TPWPPJ</odeBlockId><odeIdeviceId>20260420170508071QG2</odeIdeviceId><odeIdeviceTypeName>text</odeIdeviceTypeName><htmlView>&lt;div class="exe-text-template"&gt;&lt;div class="textIdeviceContent"&gt;
            &lt;div class="exe-text-activity"&gt;
                &lt;div&gt;&lt;p&gt;🛠️&lt;strong&gt; Tarea: Guía Interactiva de Diagnosis de Servodirecciones Asistidas&lt;/strong&gt;&lt;/p&gt;
&lt;p&gt;&lt;em&gt;&lt;strong&gt;Objetivo de la actividad:&lt;/strong&gt;&lt;/em&gt;&lt;br&gt;Crear un recurso educativo interactivo mediante la herramienta Genially que sirva como manual de diagnóstico para los diferentes tipos de servodirecciones (hidráulicas, electrohidráulicas y eléctricas).&lt;/p&gt;
&lt;p&gt;&amp;nbsp;&lt;br&gt;📋 &lt;strong&gt;Estructura del Genially&lt;/strong&gt;&lt;/p&gt;
&lt;p&gt;Tu presentación debe dividirse obligatoriamente en 4 apartados principales. Cada uno debe incluir el procedimiento escrito paso a paso y apoyarse en recursos fotográficos y vídeos (propios o seleccionados) de las actividades.&lt;/p&gt;
&lt;p&gt;&lt;strong&gt;1. Preparación y Seguridad&lt;/strong&gt; 🛡️&lt;/p&gt;
&lt;p&gt;De este nodo debe salir una ramificación que detalle:&lt;/p&gt;
&lt;p&gt;&lt;strong&gt;Tiempo:&lt;/strong&gt; Duración estimada de la preparación.&lt;br&gt;&lt;strong&gt;Espacio&lt;/strong&gt;: Zona del taller adecuada (elevador, banco de trabajo, etc.).&lt;br&gt;&lt;strong&gt;Tarea: &lt;/strong&gt;Pasos previos (limpieza, desconexión de batería, protección del vehículo).&lt;br&gt;&lt;strong&gt;Agrupamiento:&lt;/strong&gt; ¿Se trabaja individualmente o en parejas?&lt;br&gt;&lt;strong&gt;Recursos/Herramientas:&lt;/strong&gt; EPIS necesarios y material de protección.&lt;/p&gt;
&lt;p&gt;&lt;br&gt;&lt;strong&gt;2. Diagnosis y Medición&lt;/strong&gt; 🔍&lt;/p&gt;
&lt;p&gt;Ramificación detallada sobre:&lt;/p&gt;
&lt;h6&gt;&lt;strong&gt;Tiempo y Espacio:&lt;/strong&gt; Cronograma y ubicación de la prueba.&lt;/h6&gt;
&lt;h6&gt;&lt;strong&gt;Tarea 1:&lt;/strong&gt; Desmontaje y montaje de direcciones eléctricas, comprobar y verificar los componentes que la forman.&lt;/h6&gt;
&lt;h6&gt;&lt;strong&gt;Tarea 2:&lt;/strong&gt; Diagnóstico de la servodirección electromecánica, comprobar y verificar los componentes que la forman.&lt;/h6&gt;
&lt;p&gt;&lt;strong&gt;Tarea 3: &lt;/strong&gt;Diagnóstico de la bomba de dirección hidráulica, comprobar y verificar los componentes que la forman.&lt;br&gt;&lt;strong&gt;Agrupamiento:&lt;/strong&gt; Organización del equipo.&lt;br&gt;&lt;strong&gt;Herramientas utilizadas:&lt;/strong&gt; Multímetro, equipo de diagnosis, manómetro, etc.&lt;/p&gt;
&lt;p&gt;&lt;br&gt;&lt;strong&gt;3. Ajuste y Evaluación&lt;/strong&gt; ✅&lt;/p&gt;
&lt;p&gt;Ramificación con la fase de cierre de la tarea 1 una ves montada:&lt;/p&gt;
&lt;p&gt;&lt;strong&gt;Tiempo y Espacio:&lt;/strong&gt; Duración y lugar de las pruebas finales.&lt;br&gt;&lt;strong&gt;Tareas 1:&lt;/strong&gt; Ajuste de ángulos de giro y borrado de fallos.&lt;br&gt;&lt;strong&gt;Agrupamientos: &lt;/strong&gt;Quién supervisa y quién ejecuta.&lt;br&gt;&lt;strong&gt;Recursos:&lt;/strong&gt; Máquina de diagnosis, máquina de alineación.&lt;/p&gt;
&lt;p&gt;&lt;br&gt;&lt;strong&gt;4. Inconvenientes&lt;/strong&gt; ⚠️&lt;/p&gt;
&lt;p&gt;En este apartado final deberás listar los problemas más comunes encontrados durante el proceso (averías típicas, errores de montaje o dificultades técnicas) y cómo solucionarlos.&lt;/p&gt;
&lt;p&gt;&amp;nbsp;&lt;br&gt;📤 &lt;strong&gt;Requisitos de entrega:&lt;/strong&gt;&lt;/p&gt;
&lt;p&gt;&lt;strong&gt;Multimedia:&lt;/strong&gt; Es obligatorio incluir fotos y vídeos que ilustren el "paso a paso".&lt;br&gt;&lt;strong&gt;Interactividad:&lt;/strong&gt; Usa los elementos de Genially (botones, ventanas emergentes) para que la navegación sea fluida.&lt;br&gt;&lt;strong&gt;Formato:&lt;/strong&gt; Entrega el enlace público de tu Genially en el buzón de tareas en Classroom.&amp;nbsp;&lt;/p&gt;&lt;p class="clearfix"&gt;&lt;/p&gt;&lt;/div&gt;
            &lt;/div&gt;&lt;/div&gt;&lt;/div&gt;</htmlView><jsonProperties>{"ideviceId":"20260420170508071QG2","textInfoDurationInput":"","textInfoDurationTextInput":"Duración","textInfoParticipantsInput":"","textInfoParticipantsTextInput":"Agrupamiento","textTextarea":"&lt;p&gt;🛠️&lt;strong&gt; Tarea: Guía Interactiva de Diagnosis de Servodirecciones Asistidas&lt;/strong&gt;&lt;/p&gt;\n&lt;p&gt;&lt;em&gt;&lt;strong&gt;Objetivo de la actividad:&lt;/strong&gt;&lt;/em&gt;&lt;br /&gt;Crear un recurso educativo interactivo mediante la herramienta Genially que sirva como manual de diagnóstico para los diferentes tipos de servodirecciones (hidráulicas, electrohidráulicas y eléctricas).&lt;/p&gt;\n&lt;p&gt; &lt;br /&gt;📋 &lt;strong&gt;Estructura del Genially&lt;/strong&gt;&lt;/p&gt;\n&lt;p&gt;Tu presentación debe dividirse obligatoriamente en 4 apartados principales. Cada uno debe incluir el procedimiento escrito paso a paso y apoyarse en recursos fotográficos y vídeos (propios o seleccionados) de las actividades.&lt;/p&gt;\n&lt;p&gt;&lt;strong&gt;1. Preparación y Seguridad&lt;/strong&gt; 🛡️&lt;/p&gt;\n&lt;p&gt;De este nodo debe salir una ramificación que detalle:&lt;/p&gt;\n&lt;p&gt;&lt;strong&gt;Tiempo:&lt;/strong&gt; Duración estimada de la preparación.&lt;br /&gt;&lt;strong&gt;Espacio&lt;/strong&gt;: Zona del taller adecuada (elevador, banco de trabajo, etc.).&lt;br /&gt;&lt;strong&gt;Tarea: &lt;/strong&gt;Pasos previos (limpieza, desconexión de batería, protección del vehículo).&lt;br /&gt;&lt;strong&gt;Agrupamiento:&lt;/strong&gt; ¿Se trabaja individualmente o en parejas?&lt;br /&gt;&lt;strong&gt;Recursos/Herramientas:&lt;/strong&gt; EPIS necesarios y material de protección.&lt;/p&gt;\n&lt;p&gt;&lt;br /&gt;&lt;strong&gt;2. Diagnosis y Medición&lt;/strong&gt; 🔍&lt;/p&gt;\n&lt;p&gt;Ramificación detallada sobre:&lt;/p&gt;\n&lt;h6&gt;&lt;strong&gt;Tiempo y Espacio:&lt;/strong&gt; Cronograma y ubicación de la prueba.&lt;/h6&gt;\n&lt;h6&gt;&lt;strong&gt;Tarea 1:&lt;/strong&gt; Desmontaje y montaje de direcciones eléctricas, comprobar y verificar los componentes que la forman.&lt;/h6&gt;\n&lt;h6&gt;&lt;strong&gt;Tarea 2:&lt;/strong&gt; Diagnóstico de la servodirección electromecánica, comprobar y verificar los componentes que la forman.&lt;/h6&gt;\n&lt;p&gt;&lt;strong&gt;Tarea 3: &lt;/strong&gt;Diagnóstico de la bomba de dirección hidráulica, comprobar y verificar los componentes que la forman.&lt;br /&gt;&lt;strong&gt;Agrupamiento:&lt;/strong&gt; Organización del equipo.&lt;br /&gt;&lt;strong&gt;Herramientas utilizadas:&lt;/strong&gt; Multímetro, equipo de diagnosis, manómetro, etc.&lt;/p&gt;\n&lt;p&gt;&lt;br /&gt;&lt;strong&gt;3. Ajuste y Evaluación&lt;/strong&gt; ✅&lt;/p&gt;\n&lt;p&gt;Ramificación con la fase de cierre de la tarea 1 una ves montada:&lt;/p&gt;\n&lt;p&gt;&lt;strong&gt;Tiempo y Espacio:&lt;/strong&gt; Duración y lugar de las pruebas finales.&lt;br /&gt;&lt;strong&gt;Tareas 1:&lt;/strong&gt; Ajuste de ángulos de giro y borrado de fallos.&lt;br /&gt;&lt;strong&gt;Agrupamientos: &lt;/strong&gt;Quién supervisa y quién ejecuta.&lt;br /&gt;&lt;strong&gt;Recursos:&lt;/strong&gt; Máquina de diagnosis, máquina de alineación.&lt;/p&gt;\n&lt;p&gt;&lt;br /&gt;&lt;strong&gt;4. Inconvenientes&lt;/strong&gt; ⚠️&lt;/p&gt;\n&lt;p&gt;En este apartado final deberás listar los problemas más comunes encontrados durante el proceso (averías típicas, errores de montaje o dificultades técnicas) y cómo solucionarlos.&lt;/p&gt;\n&lt;p&gt; &lt;br /&gt;📤 &lt;strong&gt;Requisitos de entrega:&lt;/strong&gt;&lt;/p&gt;\n&lt;p&gt;&lt;strong&gt;Multimedia:&lt;/strong&gt; Es obligatorio incluir fotos y vídeos que ilustren el \"paso a paso\".&lt;br /&gt;&lt;strong&gt;Interactividad:&lt;/strong&gt; Usa los elementos de Genially (botones, ventanas emergentes) para que la navegación sea fluida.&lt;br /&gt;&lt;strong&gt;Formato:&lt;/strong&gt; Entrega el enlace público de tu Genially en el buzón de tareas en Classroom. &lt;/p&gt;","textFeedbackInput":"Mostrar retroalimentación","textFeedbackTextarea":""}</jsonProperties><odeComponentsOrder>1</odeComponentsOrder><odeComponentsProperties><odeComponentsProperty><key>visibility</key><value>true</value></odeComponentsProperty><odeComponentsProperty><key>teacherOnly</key><value>false</value></odeComponentsProperty><odeComponentsProperty><key>identifier</key><value/></odeComponentsProperty><odeComponentsProperty><key>cssClass</key><value/></odeComponentsProperty></odeComponentsProperties></odeComponent></odeComponents></odePagStructure></odePagStructures></odeNavStructure><odeNavStructure><odePageId>20260423164356UHRFMA</odePageId><odeParentPageId>20260423164356RPTTJR</odeParentPageId><pageName>GUIA DIDÁCTICA</pageName><odeNavStructureOrder>3</odeNavStructureOrder><odeNavStructureProperties><odeNavStructureProperty><key>titleNode</key><value>GUIA DIDÁCTICA</value></odeNavStructureProperty><odeNavStructureProperty><key>hidePageTitle</key><value>false</value></odeNavStructureProperty><odeNavStructureProperty><key>titleHtml</key><value/></odeNavStructureProperty><odeNavStructureProperty><key>editableInPage</key><value>false</value></odeNavStructureProperty><odeNavStructureProperty><key>titlePage</key><value>GUIA DIDÁCTICA</value></odeNavStructureProperty><odeNavStructureProperty><key>visibility</key><value>true</value></odeNavStructureProperty><odeNavStructureProperty><key>highlight</key><value>true</value></odeNavStructureProperty><odeNavStructureProperty><key>description</key><value/></odeNavStructureProperty></odeNavStructureProperties><odePagStructures><odePagStructure><odePageId>20260423164356UHRFMA</odePageId><odeBlockId>20260423164356BQZWQU</odeBlockId><blockName>ACTIVIADES CRITERIADAS</blockName><iconName>activity</iconName><odePagStructureOrder>1</odePagStructureOrder><odePagStructureProperties><odePagStructureProperty><key>visibility</key><value>true</value></odePagStructureProperty><odePagStructureProperty><key>teacherOnly</key><value>false</value></odePagStructurePro